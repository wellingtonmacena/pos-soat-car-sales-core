# Database connection (see docker-compose.yml for local defaults)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=car_sales_core

# HTTP server port
PORT=3000

# Base URL of the sibling "car-sales" service (vehicles + sales).
# Used by the payment webhook to call PATCH /sales/:id/payment-status.
# When running both services together on the shared `car-sales-net`
# Docker network, point this at that service's container hostname
# (e.g. http://car-sales-app:3000). When running standalone/locally
# without docker, point it at http://localhost:<car-sales-port>.
CAR_SALES_SERVICE_URL=http://localhost:3001
